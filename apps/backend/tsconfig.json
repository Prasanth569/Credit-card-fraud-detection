{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Node16",
    "paths": {
      "@enums/*": ["./src/c-types/enums/*"],
      "@schema/*": ["./src/c-types/schemas/*"]
    }
  },
  "exclude": ["node_modules", "dist", "scratch"]
}
